/* ═══════════════════════════════════════════════════════
   HOW TO SET UP STRIPE (read before deploying)
   ─────────────────────────────────────────────────────
   1. Create account at stripe.com
   2. Get your Publishable Key from Dashboard → Developers → API Keys
   3. Create a Supabase Edge Function (or a Node.js backend) that:
      a. Receives { amount, currency, metadata }
      b. Creates a PaymentIntent: stripe.paymentIntents.create(...)
      c. Returns { clientSecret }
   4. Set VITE_STRIPE_PUBLISHABLE_KEY in your .env file
   5. Set VITE_PAYMENT_ENDPOINT to your edge function URL

   .env file:b
     VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
     VITE_PAYMENT_ENDPOINT=https://your-project.supabase.co/functions/v1/create-payment-intent

   Supabase Edge Function (supabase/functions/create-payment-intent/index.ts):
     import Stripe from "https://esm.sh/stripe@14";
     const stripe = new Stripe(Deno.env.get("STRIPE_SECRET_KEY")!);
     Deno.serve(async (req) => {
       const { amount, currency = "usd", metadata } = await req.json();
       const intent = await stripe.paymentIntents.create({ amount, currency, metadata, automatic_payment_methods: { enabled: true } });
       return new Response(JSON.stringify({ clientSecret: intent.client_secret }), { headers: { "Content-Type": "application/json" } });
     });
═══════════════════════════════════════════════════════ */















